# Solana
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Backend wallet — this wallet pays for TxLINE subscription + mints assets on behalf of users.
# Generate with: solana-keygen new --outfile backend-wallet.json
# Then base58-encode the secret key array into this var, or load the JSON file directly (see solana.js).
BACKEND_WALLET_SECRET_KEY=

# TxLINE (devnet free tier — see config.js for program IDs, these don't need to be secrets)
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_SERVICE_LEVEL=1

# Storage for NFT metadata — Irys (formerly Bundlr) is the current Umi uploader
IRYS_NETWORK=devnet

# Gemini — default image generator, falls back to SVG automatically on any failure.
# Check your own Google AI Studio quota page for current free-tier limits on your account —
# this is genuinely unconfirmed/contested as of writing, don't assume a fixed number.
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Server
PORT=8080
CORS_ORIGIN=https://momentsite-sigma.vercel.app
