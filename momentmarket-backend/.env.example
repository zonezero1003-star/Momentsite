# Solana
SOLANA_NETWORK=mainnet
SOLANA_RPC_URL=https://rpc.hellomoon.io

# Backend wallet — this wallet pays for TxLINE subscription + mints assets on behalf of users.
# Generate with: solana-keygen new --outfile backend-wallet.json
# Then base58-encode the secret key array into this var, or load the JSON file directly (see solana.js).
BACKEND_WALLET_SECRET_KEY=

# TxLINE (Mainnet free tier — World Cup data)
# Service Level 1  = 60-second delay
# Service Level 12 = Real-time
TXLINE_API_ORIGIN=https://txline.txodds.com
TXLINE_SERVICE_LEVEL=12

# Storage for NFT metadata — Irys (formerly Bundlr)
IRYS_NETWORK=mainnet

# Gemini — default image generator, falls back to SVG automatically on any failure.
# Check your own Google AI Studio quota page for current free-tier limits.
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Server
PORT=8080
CORS_ORIGIN=https://momentsite-sigma.vercel.app
